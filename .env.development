# .env.development
# Konfigurasi untuk MODE LOKAL (npm run dev / XAMPP)
# File ini TIDAK perlu diupload ke server atau GitHub

# Base URL API Backend PHP (di lokal, proxy Vite yang menangani /api → localhost/deva-anime)
VITE_API_URL=/api/anime-api.php
VITE_DEVA_API_URL=

# URL Panel Admin CMS
VITE_ADMIN_URL=http://localhost/deva-anime/admin/
