# .env.production
# Konfigurasi untuk MODE PRODUCTION (build dist untuk XAMPP lokal)
# Saat deploy ke Vercel nanti, ubah nilai ini ke domain InfinityFree-mu
# atau set via Environment Variables di dashboard Vercel (lebih aman)

# Untuk XAMPP lokal: pakai relative path ke PHP backend
VITE_API_URL=/deva-anime/api/anime-api.php
VITE_DEVA_API_URL=/deva-anime

# URL Panel Admin CMS
VITE_ADMIN_URL=/deva-anime/admin/
